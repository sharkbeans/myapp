# Base shared placeholders for local and hosted environments.
# Copy values into `.env.local` for local development.
# In Vercel, add the same keys in Project Settings -> Environment Variables.

APP_ENV=development
NEXT_PUBLIC_APP_NAME=MyApp
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generic app secrets
SESSION_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-another-long-random-secret

# Neon / Postgres
# Use the pooled connection string for runtime queries.
DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_POOLED_HOST/NEON_DATABASE?sslmode=require

# Use the direct/non-pooled connection string for migrations, schema pushes, or admin scripts.
DIRECT_DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_DIRECT_HOST/NEON_DATABASE?sslmode=require

# Optional split values if your app prefers individual DB fields.
DATABASE_HOST=NEON_POOLED_HOST
DATABASE_PORT=5432
DATABASE_NAME=NEON_DATABASE
DATABASE_USER=NEON_USER
DATABASE_PASSWORD=NEON_PASSWORD
DATABASE_SSL=true
