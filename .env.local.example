# Local-only example. Copy to `.env.local` and replace all placeholders.

APP_ENV=development
NEXT_PUBLIC_APP_NAME=My Local CRUD App
NEXT_PUBLIC_APP_URL=http://localhost:3000

SESSION_SECRET=local-dev-session-secret-placeholder
CRON_SECRET=local-dev-cron-secret-placeholder

DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_POOLED_HOST/NEON_DATABASE?sslmode=require
DIRECT_DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_DIRECT_HOST/NEON_DATABASE?sslmode=require

DATABASE_HOST=NEON_POOLED_HOST
DATABASE_PORT=5432
DATABASE_NAME=NEON_DATABASE
DATABASE_USER=NEON_USER
DATABASE_PASSWORD=NEON_PASSWORD
DATABASE_SSL=true
