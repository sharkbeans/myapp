# Production example for Vercel project environment variables.
# Do not commit real production values.

APP_ENV=production
NEXT_PUBLIC_APP_NAME=My Hosted CRUD App
NEXT_PUBLIC_APP_URL=https://YOUR-PROJECT.vercel.app

SESSION_SECRET=production-session-secret-placeholder
CRON_SECRET=production-cron-secret-placeholder

DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_POOLED_HOST/NEON_DATABASE?sslmode=require
DIRECT_DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@NEON_DIRECT_HOST/NEON_DATABASE?sslmode=require

DATABASE_HOST=NEON_POOLED_HOST
DATABASE_PORT=5432
DATABASE_NAME=NEON_DATABASE
DATABASE_USER=NEON_USER
DATABASE_PASSWORD=NEON_PASSWORD
DATABASE_SSL=true
